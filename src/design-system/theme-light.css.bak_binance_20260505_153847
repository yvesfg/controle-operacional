/* ═══════════════════════════════════════════════════════════════════
   theme-light.css — Tema Claro · Controle Operacional
   Ativação: adicione data-theme="light" no <html> ou <body>
   ► Altere SOMENTE os valores aqui; nomes de variável ficam em tokens.css
   ═══════════════════════════════════════════════════════════════════ */

[data-theme="light"],
.theme-light {

  /* ── Backgrounds ─────────────────────────────────────────────── */
  --color-bg         : #f6f7fc;
  --color-bg-alt     : #eef0f8;
  --color-card       : #ffffff;
  --color-card-2     : #f0f2fa;
  --color-header-bg  : #ffffff;
  --color-modal-bg   : #ffffff;
  --color-input-bg   : #f0f2fa;
  --color-table-header: #eef0f8;

  /* ── Bordas ──────────────────────────────────────────────────── */
  --color-border     : #e0e2f0;
  --color-border-2   : #cccee0;
  --color-border-focus: #4253d4;

  /* ── Texto ───────────────────────────────────────────────────── */
  --color-text       : #16162a;
  --color-text-2     : #5a5a8a;
  --color-text-disabled: #aaaacc;
  --color-text-inverse: #ffffff;

  /* ── Acento principal — Mercury Blue (claro, contraste AA) ───── */
  --color-primary    : #4253d4;
  --color-primary-dk : #3444c0;
  --color-primary-lt : #5a6ee8;
  --color-primary-bg : rgba(66,83,212,.08);
  --color-primary-border: rgba(66,83,212,.22);

  /* ── Status ──────────────────────────────────────────────────── */
  --color-success    : #16a34a;
  --color-success-dk : #148040;
  --color-success-bg : rgba(22,163,74,.08);
  --color-success-border: rgba(22,163,74,.25);

  --color-danger     : #dc2626;
  --color-danger-dk  : #b91c1c;
  --color-danger-bg  : rgba(220,38,38,.08);
  --color-danger-border: rgba(220,38,38,.25);

  --color-warning    : #d97706;
  --color-warning-dk : #b45309;
  --color-warning-bg : rgba(217,119,6,.08);
  --color-warning-border: rgba(217,119,6,.25);

  --color-info       : #2563eb;
  --color-info-lt    : #3b82f6;
  --color-info-bg    : rgba(37,99,235,.08);
  --color-info-border: rgba(37,99,235,.25);

  /* ── Overlays / Sombras ──────────────────────────────────────── */
  --color-shadow     : rgba(0,0,0,.06);
  --color-overlay    : rgba(0,0,0,.45);
  --color-scroll-thumb: #c8cae0;

  --shadow-xs  : 0 1px 2px rgba(0,0,0,.05);
  --shadow-sm  : 0 1px 4px rgba(0,0,0,.07);
  --shadow-md  : 0 4px 12px rgba(0,0,0,.09);
  --shadow-lg  : 0 8px 24px rgba(0,0,0,.11);
  --shadow-xl  : 0 16px 48px rgba(0,0,0,.13);
  --shadow-card: 0 2px 8px rgba(0,0,0,.07);
  --shadow-primary: 0 4px 16px rgba(66,83,212,.15);

  /* ── Sidebar ─────────────────────────────────────────────────── */
  --color-sidebar-bg  : #ffffff;
  --color-sidebar-item: transparent;
  --color-sidebar-item-hover: rgba(66,83,212,.06);
  --color-sidebar-item-active: rgba(66,83,212,.10);
  --color-sidebar-text: #5a5a8a;
  --color-sidebar-text-active: #4253d4;

  /* ── Scrollbar ───────────────────────────────────────────────── */
  color-scheme: light;

  /* ── Redesign YFGroup — Semantic Tokens (light) ─────────────── */
  --bg      : #f2f3fa;
  --surface : #ffffff;
  --card    : #ffffff;
  --card2   : #f0f2fa;

  --border  : #e0e2f0;
  --border2 : #cccee0;

  --text    : #16162a;
  --text2   : #5a5a8a;
  --text3   : #9090b8;

  --accent  : #4253d4;
  --accent2 : rgba(66,83,212,.10);
  --cyan    : #0891b2;
  --green   : #16a34a;
  --orange  : #ea6c00;
  --red     : #dc2626;
  --yellow  : #ca8a04;
  --roxo    : #6d28d9;
}
