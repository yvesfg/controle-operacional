[data-theme="dark"],
.theme-dark {

  /* ── Backgrounds — Steel Blue: azul-cinza industrial frio ───── */
  --color-bg          : #0a1018;   /* deep steel floor */
  --color-bg-alt      : #111a26;   /* surface */
  --color-card        : #0f1825;   /* card */
  --color-card-2      : #172234;   /* elevated */
  --color-header-bg   : #0a1018;
  --color-modal-bg    : #111a26;
  --color-input-bg    : #0c131e;
  --color-table-header: #0a1018;

  /* ── Bordas ─────────────────────────────────────────────────── */
  --color-border      : #1c2a3d;
  --color-border-2    : #2a3a52;
  --color-border-focus: rgba(59,130,246,.40);

  /* ── Texto ───────────────────────────────────────────────────── */
  --color-text        : #e6edf6;
  --color-text-2      : #8a99b0;
  --color-text-3      : #5a6a82;
  --color-text-disabled: #3a4a62;
  --color-text-inverse: #ffffff;

  /* ── Acento principal — Steel Blue #3b82f6 ──────────────────── */
  --color-primary     : #3b82f6;
  --color-primary-dk  : #2563eb;
  --color-primary-lt  : #60a5fa;
  --color-primary-bg  : rgba(59,130,246,.12);
  --color-primary-border: rgba(59,130,246,.28);
  --color-primary-disabled: #1a2a44;

  /* ── Trading — verde sobe / vermelho desce ───────────────────── */
  --color-success     : #10b981;
  --color-success-dk  : #059669;
  --color-success-bg  : rgba(16,185,129,.12);
  --color-success-border: rgba(16,185,129,.28);

  --color-danger      : #ef4444;
  --color-danger-dk   : #dc2626;
  --color-danger-bg   : rgba(239,68,68,.12);
  --color-danger-border: rgba(239,68,68,.28);

  --color-warning     : #f59e0b;
  --color-warning-dk  : #d97706;
  --color-warning-bg  : rgba(245,158,11,.12);
  --color-warning-border: rgba(245,158,11,.28);

  --color-info        : #06b6d4;
  --color-info-lt     : #22d3ee;
  --color-info-bg     : rgba(6,182,212,.12);
  --color-info-border : rgba(6,182,212,.28);

  /* ── Overlays / Sombras ─────────────────────────────────────── */
  --color-shadow      : rgba(0,0,0,.55);
  --color-overlay     : rgba(7,12,22,.78);
  --color-scroll-thumb: #2a3a52;

  --shadow-xs         : none;
  --shadow-sm         : none;
  --shadow-md         : none;
  --shadow-lg         : 0 8px 32px rgba(0,0,0,.55);
  --shadow-xl         : 0 16px 48px rgba(0,0,0,.65);
  --shadow-card       : none;
  --shadow-primary    : 0 4px 20px rgba(59,130,246,.25);

  /* ── Sidebar ─────────────────────────────────────────────────── */
  --color-sidebar-bg        : #0a1018;
  --color-sidebar-item      : transparent;
  --color-sidebar-item-hover: rgba(59,130,246,.08);
  --color-sidebar-item-active: rgba(59,130,246,.14);
  --color-sidebar-text      : #8a99b0;
  --color-sidebar-text-active: #3b82f6;

  /* ── Scrollbar ───────────────────────────────────────────────── */
  color-scheme: dark;

  /* ── Semantic tokens — mapeados ao constants.js ──────────────── */
  --bg      : #0a1018;
  --surface : #111a26;
  --card    : #0f1825;
  --card2   : #172234;

  --border  : #1c2a3d;
  --border2 : #2a3a52;

  --text    : #e6edf6;
  --text2   : #8a99b0;
  --text3   : #5a6a82;

  --accent  : #3b82f6;
  --accent2 : rgba(59,130,246,.12);
  --on-primary: #ffffff;

  --cyan    : #06b6d4;
  --green   : #10b981;
  --orange  : #f59e0b;
  --red     : #ef4444;
  --yellow  : #eab308;
  --roxo    : #06b6d4;
}
