# ─────────────────────────────────────────────────────────
#  CONTROLE OPERACIONAL — Exemplo de configuração
# ─────────────────────────────────────────────────────────
#
#  INSTRUÇÃO PARA NOVOS COLABORADORES:
#  1. Copie este arquivo e renomeie para .env.local
#  2. Solicite ao admin as credenciais do Supabase
#  3. Preencha os valores abaixo
#  4. Rode: npm run dev
#
# ─────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_KEY=sua_anon_key_aqui

# URL do Frota Pro (hub SSO)
# Produção: URL da Vercel do frota-pro (ex: https://frota-pro.vercel.app)
# Dev local: http://localhost:3000
VITE_FROTA_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────
#  CAMADA DE IA (análise de documentos) — SÓ NO SERVIDOR
#  Sem prefixo VITE_ → nunca exposto no front. Configurar na Vercel.
# ─────────────────────────────────────────────────────────
# Chave da API de IA (ex.: Google Gemini — generativelanguage.googleapis.com)
AI_API_KEY=sua_chave_de_ia_aqui
# Provedor (default: gemini). Trocar de IA = adaptar api/_ai/provider.js
AI_PROVIDER=gemini
# Modelo (default: gemini-2.0-flash)
AI_MODEL=gemini-2.0-flash
# Token do gateway (/api/ai-extract). Se setado, exige header x-ai-token.
# Deixe vazio para mesmo-domínio; obrigatório se outros apps consumirem o gateway.
AI_GATEWAY_TOKEN=
