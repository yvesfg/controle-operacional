# ─────────────────────────────────────────────────────────
#  CONTROLE OPERACIONAL — Exemplo de configuração
# ─────────────────────────────────────────────────────────
#
#  INSTRUÇÃO PARA NOVOS COLABORADORES:
#  1. Copie este arquivo e renomeie para .env.local
#  2. Solicite ao admin as credenciais do Supabase
#  3. Preencha os valores abaixo
#  4. Rode: npm run dev
#
# ─────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_KEY=sua_anon_key_aqui

# URL do Frota Pro (hub SSO)
# Produção: URL da Vercel do frota-pro (ex: https://frota-pro.vercel.app)
# Dev local: http://localhost:3000
VITE_FROTA_URL=http://localhost:3000
