# ── Provedor de IA (chave fica SÓ aqui, nunca nos apps) ──
AI_API_KEY=sua_chave_gemini_aqui
AI_PROVIDER=gemini               # gemini | (futuro: openai | claude)
AI_MODEL=gemini-2.0-flash

# ── Autenticação do gateway ──────────────────────────────
# Token que os apps enviam no header x-ai-token.
# Gere com: openssl rand -hex 32
AI_GATEWAY_TOKEN=gere_um_token_aleatorio_aqui

# ── Origens permitidas (CORS) ────────────────────────────
# URLs dos apps que chamam o gateway, separadas por vírgula.
ALLOWED_ORIGINS=https://controle-operacional.vercel.app,https://frota-yfgroup.vercel.app,https://yffinance.vercel.app
